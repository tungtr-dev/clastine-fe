{
	"compilerOptions": {
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"baseUrl": "src",
		"paths": {
			"@components/application/core": ["components/application/core/index.ts"],
			"@components/application/layout": ["components/application/layout/index.ts"],
			"@components/application/shared": ["components/application/shared/index.ts"],
			"@components/common/data": ["components/common/data/index.ts"],
			"@components/common/input": ["components/common/input/index.ts"],
			"@components/common/overlay": ["components/common/overlay/index.ts"],
			"@components/common/types": ["components/common/types/index.ts"],
			"@store": ["data/store/index.ts"],
			"@store/slices": ["data/store/slices/index.ts"],
			"@constants": ["constants/index.ts"],
			"@contexts": ["utilities/contexts/index.ts"],
			"@functions": ["utilities/functions/index.ts"],
			"@hooks": ["utilities/hooks/index.ts"],
			"@initializer": ["utilities/initializer/initializer.ts"]
		}
	}
}